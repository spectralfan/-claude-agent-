{
  "mcpServers": {
    "jchatmind-shell": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "node",
        "scripts/mcp/jchatmind-shell-mcp.mjs"
      ],
      "env": {
        "JCHATMIND_MCP_PLATFORM": "windows",
        "JCHATMIND_MCP_EXECUTOR": "powershell",
        "JCHATMIND_PREVIEW_PORT": "5500",
        "JCHATMIND_RESERVED_PORTS": "8080,3000,5173"
      }
    }
  }
}