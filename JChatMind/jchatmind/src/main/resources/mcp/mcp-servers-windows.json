{
  "mcpServers": {
    "jchatmind-shell": {
      "comment": "Spring AI 官方 Windows STDIO 格式：npx/node 须 cmd.exe /c 包装",
      "command": "cmd.exe",
      "args": [
        "/c",
        "node",
        "Z:/JAVA_workshop/JChatMindv2/JChatMind/jchatmind/scripts/mcp/jchatmind-shell-mcp.mjs"
      ],
      "env": {
        "JCHATMIND_MCP_PLATFORM": "windows",
        "JCHATMIND_MCP_EXECUTOR": "powershell"
      }
    }
  }
}
